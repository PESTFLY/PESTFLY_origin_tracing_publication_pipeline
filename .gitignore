# =============================================================================
# R / RStudio
# =============================================================================

.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj

# =============================================================================
# Operating-system files
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Temporary / backup files
# =============================================================================

*.tmp
*.bak
*.old
~$*

# =============================================================================
# Exclude raw/reference PHYLIP alignment input
# =============================================================================
# The full PHYLIP ortholog alignment database is distributed separately
# under controlled access. It is not stored in GitHub.

data/**/phy/
data/**/phy/**
phy/
**/phy/
**/phy/**

*.phy
*.phylip

# =============================================================================
# Exclude generated FASTA files
# =============================================================================
# results/00_fasta/ is regenerated by Step 00 from data/phy/.
# It is excluded because it contains thousands of generated FASTA files.

results/00_fasta/
results/00_fasta/**
*.fasta
*.fa
*.fas

# =============================================================================
# Exclude very large generated QC matrix
# =============================================================================
# This file is too large for normal GitHub upload.
# Keep smaller QC summaries and all downstream results.

results/01_qc/sample_missingness.tsv
results/01_qc/sample_missingness.tsv.gz

# =============================================================================
# Keep public metadata and documentation
# =============================================================================

!data/
!data/000_input_data/
!data/000_input_data/metadata.xlsx

!README.md
!**/README.md
!**/README_*.md
!results/README_results.md
!data/README_data.md